            "body": "#4a5568",
            "muted": "#718096"
        },
        "accent": {
            "primary": "#c53030",
            "secondary": "#e53e3e",
            "highlight": "#c53030",
            "link": "#2b6cb0"
        },
        "diagram": {
            "box_border": "#2c5282",
            "box_fill": "#edf2f7",
            "arrow": "#4a5568",
            "highlight_box": "#c53030"
        }
    },
    "typography": {
        "title": {
            "font_family": "PingFang SC, Microsoft YaHei, Arial, sans-serif",
            "font_size_pt": 36,
            "font_weight": "bold",
            "color": "#1e3a5f"
        },
        "subtitle": {
            "font_family": "PingFang SC, Microsoft YaHei, Arial, sans-serif",
            "font_size_pt": 18,
            "font_weight": "normal",
            "color": "#4a5568"
        },
        "body": {
            "font_family": "PingFang SC, Microsoft YaHei, Arial, sans-serif",
            "font_size_pt": 14,
            "line_height": 1.6
        },
        "english": {
            "font_family": "Arial, Helvetica, sans-serif",
